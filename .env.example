APP_NAME=Book Vector Query API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001


QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=books_collection

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=intfloat/multilingual-e5-small
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_DIMENSIONS=768
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true

LLM_PROVIDER=openai-compatible
# For Gemini: https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_BASE=
# For Gemini, put your Gemini API Key here (e.g. AIzaSy...)
LLM_API_KEY=
# For Gemini: gemini-1.5-flash or gemini-1.5-pro or gemini-2.0-flash
LLM_MODEL=
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=30

DEFAULT_TOP_K=10
DEFAULT_CANDIDATE_LIMIT=30
DEFAULT_SCORE_THRESHOLD=
DEFAULT_LLM_MIN_SCORE=0.60

API_TIMEOUT_SECONDS=200
LOG_QUERY_CONTENT=false
FRONTEND_URLS=http://localhost:3001,http://127.0.0.1:3001
